{%- set my_file_name  = ctx.root_namespace | pascal_case ~ "Metrics.cs" -%}
{%- set my_class_name = ctx.root_namespace | pascal_case ~ "Metrics" -%}
{%- set meter_name    = ctx.root_namespace | upper_case -%}
{{- template.set_file_name(my_file_name) -}}
{%- macro field_name(metric) -%}
{{ metric.metric_name | pascal_case }}
{%- endmacro -%}
{%- macro csharp_type(instrument) -%}
{%- if instrument == "counter" -%}Counter<long>
{%- elif instrument == "updowncounter" -%}UpDownCounter<long>
{%- elif instrument == "histogram" -%}Histogram<double>
{%- elif instrument == "gauge" -%}ObservableGauge<double>
{%- else -%}Counter<long>
{%- endif -%}
{%- endmacro -%}
{%- macro create_method(instrument) -%}
{%- if instrument == "counter" -%}CreateCounter<long>
{%- elif instrument == "updowncounter" -%}CreateUpDownCounter<long>
{%- elif instrument == "histogram" -%}CreateHistogram<double>
{%- elif instrument == "gauge" -%}CreateObservableGauge<double>
{%- else -%}CreateCounter<long>
{%- endif -%}
{%- endmacro -%}

