// <auto-generated>This file has been auto generated from 'Templates\Registry\Csharp\SemanticConventionsMetrics.cs.j2' </auto-generated>

#nullable enable

using System.Diagnostics.Metrics;

namespace Shared;

/// <summary>
/// Metric instrument definitions for the {{ meter_name }} service.
/// </summary>
public static class {{ my_class_name }}
{
    /// <summary>
    /// The name of the meter. Use this value to register the meter with OpenTelemetry via <c>AddMeter</c>.
    /// </summary>
    public const string MeterName = "{{ meter_name }}";

    private static readonly Meter s_meter = new(MeterName, "1.0.0");

{% for metric in ctx.metrics %}
{% set name = field_name(metric) %}
{% if not loop.first %}{{"\n"}}{% endif %}
    {{ metric.brief | comment(indent=4) }}
{% if metric.note %}
    {{ metric.note | comment(header="/// <remarks>", footer="/// </remarks>", indent=4) }}
{% endif %}
    public static readonly {{ csharp_type(metric.instrument) }} {{ name }} =
        s_meter.{{ create_method(metric.instrument) }}("{{ metric.metric_name }}", "{{ metric.unit }}", "{{ metric.brief | trim | replace("\n", " ") }}");
{% endfor %}
}

